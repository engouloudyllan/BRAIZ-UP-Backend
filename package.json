{
  "name": "braiz-up-backend",
  "version": "1.0.0",
  "description": "API backend pour projet BRAIZ UP",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx ./src/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "rimraf dist && tsc && cp -r public dist/",
    "start": "node dist/src/index.js",
    "serve": "concurrently \"tsc -w\" \"nodemon --exec node dist/src/index.js\"",
    "postinstall": "prisma generate",
    "preserve": "yarn build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/engouloudyllan/BRAIZ-UP-Backend.git"
  },
  "author": "dyllan-lc",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/engouloudyllan/BRAIZ-UP-Backend/issues"
  },
  "homepage": "https://github.com/engouloudyllan/BRAIZ-UP-Backend#readme",
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/config": "^7.8.0",
    "@types/express": "^5.0.6",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.6",
    "db": "^6.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "nodemailer": "^8.0.8",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "seed": "^0.4.4",
    "typescript": "^6.0.3",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cookie-session": "^2.0.49",
    "@types/cors": "^2.8.19",
    "@types/express-fileupload": "^1.5.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3"
