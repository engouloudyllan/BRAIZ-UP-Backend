// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique(map: "email_unique")
  password     String
  userName     String?  @unique(map: "userName_unique")
  firstName    String?  @db.VarChar(255)
  lastName     String?  @db.VarChar(255)
  phoneNumber  String?  @db.VarChar(255)
  profileImage String?  @db.VarChar(255)
  responsable  String?  @db.VarChar(255)
  companyName  String?  @db.VarChar(255)
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  roles         UserHasRoles[]
  shippingZones Address[]
  cart          Cart?
  orders        Order[]
  sessions      Session[]
  otps          Otp[]
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique(map: "token_unique")
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Otp {
  id        Int      @id @default(autoincrement())
  code      String   @db.VarChar(6)
  type      OtpType
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model UserHasRoles {
  userId Int
  roleId Int

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model Role {
  id          Int      @id @default(autoincrement())
  title       String   @unique(map: "title_unique")
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  users       UserHasRoles[]
  permissions RoleHasPermissions[]
}

model RoleHasPermissions {
  roleId       Int
  permissionId Int

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Permission {
  id          Int      @id @default(autoincrement())
  title       String   @unique(map: "title_unique")
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  roles RoleHasPermissions[]
}

model Cart {
  id        Int        @id @default(autoincrement())
  sessionId String?    @unique(map: "sessionId_unique") // ça sert généralement à gérer: les paniers des utilisateurs NON connectés (guest carts)
  status    CartStatus @default(ACTIVE)
  expiresAt DateTime
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt

  userId Int?       @unique(map: "userId_unique")
  user   User?      @relation(fields: [userId], references: [id])
  item   CartItem[]
}

enum CartStatus {
  ACTIVE
  ABANDONED
  CONVERTED
}

model CartItem {
  quantity  Int
  unitPrice Float
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  productId Int
  cartId    Int
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@id([cartId, productId])
}

model Product {
  id              Int      @id @default(autoincrement())
  name            String   @unique(map: "name_unique") @db.VarChar(255)
  description     String   @db.LongText
  images          Json
  price           Float    @db.Float
  stock           Int      @default(0)
  cookingDuration Int
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  categoryId      Int
  category        Category @relation(fields: [categoryId], references: [id])

  cartItems  CartItem[]
  orderItems OrderItem[]
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique(map: "name_unique") @db.VarChar(255)
  description String?  @db.LongText
  image       String   @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  products Product[]
}

model GlobalSettings {
  id             Int      @id @default(autoincrement())
  companyName    String   @db.VarChar(255)
  companyAddress String   @db.VarChar(255)
  logo           String   @db.VarChar(255)
  companyEmail   String   @db.VarChar(255)
  companyPhone   String   @db.VarChar(255)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
}

model Region {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  cities City[]
}

model City {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(255)

  regionId Int
  region   Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  districts District[] // Une ville peut avoir plusieurs quartiers

  @@unique([name, regionId])
}

model District {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(255)

  cityId Int
  city   City @relation(fields: [cityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  neighborhoods Neighborhood[]
  shippingZones ShippingZone[]

  @@unique([name, cityId])
}

model Neighborhood {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(255)

  districtId Int
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  shippingZones ShippingZone[]

  @@unique([name, districtId])
}

model ShippingZone {
  id          Int     @id @default(autoincrement())
  name        String  @unique(map: "name_unique") @db.VarChar(255)
  fee         Float   @db.Float
  description String? @db.LongText
  isActive    Boolean @default(true)

  districtId     Int
  neighborhoodId Int?

  district     District      @relation(fields: [districtId], references: [id])
  neighborhood Neighborhood? @relation(fields: [neighborhoodId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  addresses Address[]
  orders    Order[]
}

model Address {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  street    String   @db.VarChar(255)
  details   String?  @db.LongText
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  orders         Order[]
  userId         Int
  shippingZoneId Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingZone   ShippingZone @relation(fields: [shippingZoneId], references: [id])
}

model Order {
  id                  Int           @id @default(autoincrement())
  codeTicket          String        @unique
  totalProducts       Float         @db.Float
  shippingFee         Float         @db.Float
  shippingAddress     String        @db.VarChar(255)
  paymentProofUrl     String        @db.VarChar(255)
  totalAmount         Float         @db.Float
  isDeliveryRequested Boolean       @default(false)
  deliveryTime        DateTime?
  proximityAddress    String?       @db.VarChar(100)
  status              OrderStatus
  paymentMethod       paymentMethod
  customerType        CustomerType

  confirmedAt DateTime? // Date de confirmation de la commande
  paidAt      DateTime? // Date de paiement de la commande
  preparingAt DateTime? // Date de préparation de la commande
  readyAt     DateTime? // Date de préparation terminée
  deliveredAt DateTime? // Date de livraison

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trackingToken    String  @unique @default(uuid()) // Génère le token unique pour l'URL de suivi
  guestName        String? @db.VarChar(255) // Nom de l'invité si pas de compte
  guestSurname     String? @db.VarChar(255) // Prénom de l'invité si pas de compte
  guestCompanyName String? @db.VarChar(255) // Nom de l'entreprise de l'invité si pas de compte
  guestResponsable String? @db.VarChar(255) // Responsable de l'invité si pas de compte
  guestPhone       String? @db.VarChar(255) // Téléphone de l'invité si pas de compte
  guestEmail       String? @db.VarChar(255) // Email de l'invité si pas de compte
  guestCity        String? @db.VarChar(255) // Ville de l'invité si pas de compte

  items          OrderItem[]
  userId         Int?
  shippingZoneId Int
  AddressId      Int?
  Address        Address?     @relation(fields: [AddressId], references: [id])
  shippingZone   ShippingZone @relation(fields: [shippingZoneId], references: [id])
  user           User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CustomerType {
  PARTICULIER
  ENTREPRISE
}

enum OrderStatus {
  EN_PRECOMMANDE
  EN_COURS_DE_PREPARATION
  PRÊTE
  EN_LIVRAISON
  LIVRÉE
  ANNULÉE
}

enum paymentMethod {
  ORANGE_MONEY
  MTN_MOBILE_MONEY
  CASH_ON_DELIVERY
}

model OrderItem {
  quantity  Int
  unitPrice Float
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  productId Int
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@id([orderId, productId])
}
